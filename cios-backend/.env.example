DATABASE_URL=postgresql://user:password@localhost:5432/cios
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000

# Render injects PORT automatically in production.
PORT=3000

JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session idle timeout (ms) - 4 hours per PRD spec
SESSION_IDLE_TIMEOUT_MS=14400000

# Workspace invitation email flow
RESEND_API_KEY=your_resend_api_key_here
# Must use a domain verified in Resend to send to real invitees.
RESEND_FROM_EMAIL=CIOS <noreply@yourdomain.com>
# Optional: when absent, invitation emails include the token instead of a link.
FRONTEND_URL=http://localhost:3000
